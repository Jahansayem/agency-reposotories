# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
**/.next/
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm-cache/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
*.db
*.sqlite
prisma/*.db

# playwright
**/test-results/
**/playwright-report/
**/playwright/.cache/
screenshots/
playwright.config.local.ts

# playwright-mcp debug artifacts
.playwright-mcp/console-*.log
.playwright-mcp/page-*.png

# debug/test screenshots at repo root (preserves public/ and test-assets/)
/*.png
debug-*.png
review-*.png
*-test-*.png

# Sentry
.sentryclirc

# Supabase
supabase/.temp/

# iOS
ios-app/SharedTodoList/Resources/Secrets.plist
*.xcuserstate
*.xcworkspace
xcuserdata/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM
*.p8
.mcp.json
.worktrees/

# Sensitive data - NEVER commit PII
src/data/bealer-model/
src/data/**/*.csv
src/data/**/*.pdf
!src/data/**/README.md
!src/data/**/.gitkeep
